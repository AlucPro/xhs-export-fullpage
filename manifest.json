{
  "manifest_version": 3,
  "name": "小红书导出长图",
  "version": "1.0.0",
  "description": "将小红书帖子导出为长图，支持单个帖子和收藏夹批量导出",
  "permissions": ["storage", "downloads", "scripting"],
  "host_permissions": [
    "*://www.xiaohongshu.com/*",
    "*://sns-webpic-qc.xhscdn.com/*",
    "*://ci.xiaohongshu.com/*"
  ],
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "小红书导出长图"
  },
  "content_scripts": [
    {
      "matches": ["*://www.xiaohongshu.com/explore/*"],
      "js": ["src/content/post.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.xiaohongshu.com/user/profile/*"],
      "js": ["src/content/favorites.ts"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  }
}
